# Postgres connection string for match history storage (Supabase).
# Required for the /api/matches endpoint and match-history persistence.
# Without it, the server still runs but does not persist matches.
DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/postgres?sslmode=require

# Match-history public-write gate. Reads (/api/matches) work whenever DATABASE_URL is set.
# When truthy (1/true/yes/on), writes are public and visible from beta/mainline. When falsy,
# writes are tagged local_only and only loopback reads include them.
# Beta and mainline deploys should set this to 1.
RTS_RECORD_MATCHES=0

# Supabase project URL and publishable (anon) key. Safe to expose.
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_XXXX

# Read-only Fly API token for agent log inspection via scripts/fly-logs.sh.
# Create with:
#   flyctl tokens create readonly --org personal --name codex-rts-logs --expiry 175200h0m0s
FLY_API_TOKEN=fm2_READ_ONLY_TOKEN
