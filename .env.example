# Postgres connection string for match history and client stress-test storage (Supabase).
# Without it, the server still runs but does not persist either artifact class.
DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/postgres?sslmode=require

# Match-history public-write gate. Reads (/api/matches) work whenever DATABASE_URL is set.
# When truthy (1/true/yes/on), beta/mainline write match rows and replay artifacts.
# When falsy, the server performs no match-history writes.
# Beta and mainline deploys should set this to 1.
RTS_RECORD_MATCHES=0

# Client-only Hellhole stress-test persistence gate. Accepted runs are always logged and retained
# in a bounded in-process cache; set this to 1 on beta/mainline to persist artifacts to Postgres.
# Keep it off for local cargo run so local tests do not write to a shared database.
RTS_RECORD_STRESS_TESTS=0

# Supabase project URL and publishable (anon) key. Safe to expose.
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_XXXX

# Read-only Fly API token for agent log inspection via scripts/fly-logs.sh.
# Create with:
#   flyctl tokens create readonly --org personal --name codex-rts-logs --expiry 175200h0m0s
FLY_API_TOKEN=fm2_READ_ONLY_TOKEN
