{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "RTS Mac Cursor Shell",
  "version": "0.1.0",
  "identifier": "dev.bewegungskrieg.MacCursorShell",
  "build": {},
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Bewegungskrieg",
        "width": 1280,
        "height": 820,
        "minWidth": 960,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false,
        "create": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "icon": [
      "icons/icon.png"
    ],
    "targets": "app",
    "macOS": {
      "minimumSystemVersion": "13.0"
    }
  }
}
