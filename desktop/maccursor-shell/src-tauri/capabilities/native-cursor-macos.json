{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "native-cursor-macos",
  "description": "macOS-only native cursor command permissions for the desktop shell window.",
  "platforms": [
    "macOS"
  ],
  "remote": {
    "urls": [
      "https://rts-0-zvorygin-beta.fly.dev/*",
      "https://rts-0-zvorygin.fly.dev/*",
      "http://127.0.0.1:*",
      "http://localhost:*"
    ]
  },
  "windows": [
    "main"
  ],
  "permissions": [
    "allow-maccursor-start",
    "allow-maccursor-configure",
    "allow-maccursor-stop",
    "allow-maccursor-diagnostics"
  ]
}
