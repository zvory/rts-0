{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Cross-platform shell permissions for the desktop window.",
  "remote": {
    "urls": [
      "https://rts-0-zvorygin-beta.fly.dev/*",
      "https://rts-0-zvorygin.fly.dev/*",
      "http://127.0.0.1:*",
      "http://localhost:*"
    ]
  },
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "allow-desktop-log-info",
    "allow-desktop-reveal-logs",
    "allow-desktop-log-client-event",
    "allow-desktop-open-profile",
    "allow-desktop-return-to-startup"
  ]
}
