{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Pointer Lock Lab",
  "version": "0.1.0",
  "identifier": "dev.pointerlock.lab",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Pointer Lock Lab",
        "width": 1180,
        "height": 850,
        "minWidth": 900,
        "minHeight": 700,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self'; img-src 'self' data:; connect-src 'none'; object-src 'none'; frame-src 'none'"
    }
  },
  "bundle": {
    "active": false,
    "icon": [
      "icons/icon.png",
      "icons/icon.ico"
    ]
  }
}
