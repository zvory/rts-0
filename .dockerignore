# Keep the deploy context aligned with the Dockerfile COPY inputs. New build
# inputs must be explicitly added here instead of uploading the whole checkout.
**

!Dockerfile

!server/
!server/Cargo.toml
!server/Cargo.lock
!server/crates/
!server/crates/**
!server/src/
!server/src/**
!server/assets/
!server/assets/**
!server/migrations/
!server/migrations/**

!client/
!client/**

!scripts/
!scripts/build-sim-wasm.sh

# The deployed wiki reads only these allowlisted documentation trees.
!docs/
!docs/context/
!docs/context/**
!docs/design/
!docs/design/**

